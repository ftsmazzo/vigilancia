# PostgreSQL
POSTGRES_DB=vigsocial
POSTGRES_USER=vigsocial
POSTGRES_PASSWORD=vigsocial_dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8000
DATABASE_URL=postgresql+psycopg://vigsocial:vigsocial_dev@postgres:5432/vigsocial
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# URLs do frontend permitidas pelo CORS (virgula). Em producao use o dominio publico do app.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bootstrap do SuperAdmin (usar no primeiro deploy)
BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@prefeitura.local
BOOTSTRAP_SUPERADMIN_PASSWORD=trocar-no-easypanel
BOOTSTRAP_SUPERADMIN_NAME=Super Admin
# true = na subida, atualiza senha do e-mail acima se o usuário já existir (após trocar senha no painel)
BOOTSTRAP_SUPERADMIN_SYNC_PASSWORD=false

# Assistente de vigilância (OpenAI ou API compatível)
# ASSIST_LLM_API_KEY=sk-...
# ASSIST_LLM_BASE_URL=https://api.openai.com/v1
# ASSIST_LLM_MODEL=gpt-4o-mini
# CADU_DICTIONARY_PATH=/caminho/dicionariotudo.csv

# Frontend
WEB_PORT=3000
VITE_API_URL=http://localhost:8000
